{
  "name": "agentic-infra",
  "version": "0.0.1",
  "description": "AI 기반 인프라/백엔드 자동 구성 CLI 도구",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agentic-infra": "./dist/index.js"
  },
  "scripts": {
