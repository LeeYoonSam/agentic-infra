// Type-safe API Client for <%= name %>
// Generated by Agentic Infra

export interface ApiResponse<T> {
  data: T;
  error: null;
}

export interface ApiError {
  data: null;
  error: {
    message: string;
    statusCode: number;
  };
}

export type ApiResult<T> = ApiResponse<T> | ApiError;

export interface RequestConfig {
  baseUrl?: string;
  headers?: Record<string, string>;
  timeout?: number;
}

<% if (hasAuth) { %>
// WARNING: 모듈 레벨 상태 — 브라우저(SPA) 전용.
// SSR에서는 이 토큰이 모든 동시 요청에 공유되어 사용자 간 토큰이 누출됩니다.
// Next.js 서버 컴포넌트 등에서는 요청별로 RequestConfig.headers를 통해 토큰을 전달하세요.
let authToken: string | null = null;

export function setAuthToken(token: string | null): void {
  authToken = token;
}

export function getAuthToken(): string | null {
  return authToken;
}
<% } %>

const DEFAULT_BASE_URL = process.env.API_BASE_URL ?? 'http://localhost:3000/api';

async function request<T>(
  method: string,
  endpoint: string,
  body?: unknown,
  config?: RequestConfig,
): Promise<ApiResult<T>> {
  const baseUrl = config?.baseUrl ?? DEFAULT_BASE_URL;
  const url = `${baseUrl}${endpoint}`;

  const headers: Record<string, string> = {
    'Content-Type': 'application/json',
    ...config?.headers,
  };

<% if (hasAuth) { %>
  if (authToken) {
    headers['Authorization'] = `Bearer ${authToken}`;
  }
<% } %>

  try {
    const controller = new AbortController();
    const timeout = config?.timeout ?? 30000;
    const timeoutId = setTimeout(() => controller.abort(), timeout);

    const response = await fetch(url, {
      method,
      headers,
      ...(body ? { body: JSON.stringify(body) } : {}),
      signal: controller.signal,
    });

    clearTimeout(timeoutId);

    if (!response.ok) {
      const errorBody = await response.json().catch(() => ({}));
      return {
        data: null,
        error: {
          message: (errorBody as Record<string, string>).message ?? response.statusText,
          statusCode: response.status,
        },
      };
    }

    const data = await response.json() as T;
    return { data, error: null };
  } catch (err) {
    return {
      data: null,
      error: {
        message: (err as Error).message,
        statusCode: 0,
      },
    };
  }
}

export const api = {
  get: <T>(endpoint: string, config?: RequestConfig) =>
    request<T>('GET', endpoint, undefined, config),

  post: <T>(endpoint: string, body: unknown, config?: RequestConfig) =>
    request<T>('POST', endpoint, body, config),

  put: <T>(endpoint: string, body: unknown, config?: RequestConfig) =>
    request<T>('PUT', endpoint, body, config),

  patch: <T>(endpoint: string, body: unknown, config?: RequestConfig) =>
    request<T>('PATCH', endpoint, body, config),

  delete: <T>(endpoint: string, config?: RequestConfig) =>
    request<T>('DELETE', endpoint, undefined, config),
};
