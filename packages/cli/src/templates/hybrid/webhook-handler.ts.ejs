// Supabase Webhook → Lambda Handler for <%= name %>
// Generated by Agentic Infra
// Supabase Database Webhooks에서 이 Lambda를 호출합니다.

interface WebhookPayload {
  type: 'INSERT' | 'UPDATE' | 'DELETE';
  table: string;
  record: Record<string, unknown>;
  old_record: Record<string, unknown>;
  schema: string;
}

interface LambdaResponse {
  statusCode: number;
  body: string;
}

export async function handler(event: { body: string }): Promise<LambdaResponse> {
  const payload: WebhookPayload = JSON.parse(event.body);

  console.log(`[Webhook] ${payload.type} on ${payload.schema}.${payload.table}`);

  try {
    switch (payload.type) {
      case 'INSERT':
        await onInsert(payload);
        break;
      case 'UPDATE':
        await onUpdate(payload);
        break;
      case 'DELETE':
        await onDelete(payload);
        break;
    }

    return { statusCode: 200, body: JSON.stringify({ success: true }) };
  } catch (error) {
    console.error('[Webhook Error]', error);
    return { statusCode: 500, body: JSON.stringify({ error: (error as Error).message }) };
  }
}

