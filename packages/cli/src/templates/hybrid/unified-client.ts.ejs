// Unified API Client for <%= name %>
// Generated by Agentic Infra
// Supabase(DB/Auth) + AWS Lambda(비즈니스 로직)을 하나의 인터페이스로 통합

import { supabase } from './supabase.js';

const LAMBDA_API_URL = process.env.LAMBDA_API_URL ?? '';

interface RequestOptions {
  method?: string;
  body?: unknown;
  headers?: Record<string, string>;
}

async function getAuthToken(): Promise<string | null> {
  const { data: { session } } = await supabase.auth.getSession();
  return session?.access_token ?? null;
}

async function lambdaFetch<T>(endpoint: string, options?: RequestOptions): Promise<T> {
  const token = await getAuthToken();

  const response = await fetch(`${LAMBDA_API_URL}${endpoint}`, {
    method: options?.method ?? 'GET',
    headers: {
      'Content-Type': 'application/json',
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
      ...options?.headers,
    },
    ...(options?.body ? { body: JSON.stringify(options.body) } : {}),
  });

  if (!response.ok) {
    throw new Error(`API error: ${response.status} ${response.statusText}`);
  }

  return response.json() as Promise<T>;
}

// ===== Supabase 직접 접근 (DB/Auth) =====

export const db = {
  async query<T>(table: string, filters?: Record<string, unknown>) {
    let query = supabase.from(table).select('*');
    if (filters) {
      for (const [key, value] of Object.entries(filters)) {
        query = query.eq(key, value);
      }
    }
    const { data, error } = await query;
    if (error) throw error;
    return data as T[];
  },

  async insert<T>(table: string, record: Partial<T>) {
    const { data, error } = await supabase.from(table).insert(record).select();
    if (error) throw error;
    return data[0] as T;
  },

  async update<T>(table: string, id: string, updates: Partial<T>) {
    const { data, error } = await supabase.from(table).update(updates).eq('id', id).select();
    if (error) throw error;
    return data[0] as T;
  },

  async remove(table: string, id: string) {
    const { error } = await supabase.from(table).delete().eq('id', id);
    if (error) throw error;
  },
};

export const auth = {
  signUp: (email: string, password: string) => supabase.auth.signUp({ email, password }),
  signIn: (email: string, password: string) => supabase.auth.signInWithPassword({ email, password }),
  signOut: () => supabase.auth.signOut(),
  getUser: () => supabase.auth.getUser(),
};

// ===== AWS Lambda (복잡한 비즈니스 로직) =====

export const api = {
  get: <T>(endpoint: string) => lambdaFetch<T>(endpoint),
  post: <T>(endpoint: string, body: unknown) => lambdaFetch<T>(endpoint, { method: 'POST', body }),
  put: <T>(endpoint: string, body: unknown) => lambdaFetch<T>(endpoint, { method: 'PUT', body }),
  delete: <T>(endpoint: string) => lambdaFetch<T>(endpoint, { method: 'DELETE' }),
};
