    // Arrange → Act → Assert
  });

  it('가설 2: 잘못된 입력 → 에러', async () => {
    // Arrange → Act → Assert
  });

  it('경계 조건: 빈 값 처리', async () => {
    // Arrange → Act → Assert
  });
});
```
<% } -%>

