{
  "hooks": {
    "PreCommit": [
      {
        "command": "npx tsc --noEmit",
        "description": "TypeScript 타입 검사"
      },
      {
        "command": "npx eslint . --max-warnings 0",
        "description": "ESLint 검사"
      },
      {
        "command": "npx vitest run --reporter=dot 2>/dev/null || true",
        "description": "테스트 실행"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "**/package.json",
        "command": "echo '의존성 변경 감지. /sync-docs로 문서 동기화를 실행하세요.'",
        "description": "의존성 변경 시 문서 동기화 안내"
      }<% if (clients.includes('android')) { %>,
      {
        "matcher": "**/*.gradle.kts",
        "command": "echo 'Gradle 설정 변경 감지. /sync-docs로 문서 동기화를 실행하세요.'",
        "description": "Gradle 변경 시 문서 동기화 안내"
      }<% } %><% if (clients.includes('flutter')) { %>,
      {
        "matcher": "**/pubspec.yaml",
        "command": "echo 'pubspec 변경 감지. /sync-docs로 문서 동기화를 실행하세요.'",
        "description": "Flutter 의존성 변경 시 문서 동기화 안내"
      }<% } %>
    ]
  },
  "permissions": {
    "allow": [
      "npx tsc *",
      "npx eslint *",
      "npx prettier *",
      "npm run *"<% if (stack === 'supabase' || stack === 'hybrid') { %>,
      "supabase *"<% } %><% if (stack === 'aws' || stack === 'hybrid') { %>,
      "npx cdk *"<% } %><% if (deploy === 'vercel') { %>,
      "vercel *"<% } %>
    ]
  }
}
