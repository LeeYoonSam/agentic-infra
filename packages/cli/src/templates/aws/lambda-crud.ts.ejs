// Lambda CRUD Handler for <%= name %>
// Generated by Agentic Infra

<% if (features.includes('database')) { %>
import { DynamoDBClient } from '@aws-sdk/client-dynamodb';
import { DynamoDBDocumentClient, GetCommand, PutCommand, QueryCommand, DeleteCommand } from '@aws-sdk/lib-dynamodb';

const client = new DynamoDBClient({});
const docClient = DynamoDBDocumentClient.from(client);
const TABLE_NAME = process.env.TABLE_NAME ?? '';
<% } %>

interface ApiEvent {
  httpMethod: string;
  path: string;
  body: string | null;
  pathParameters: Record<string, string> | null;
  queryStringParameters: Record<string, string> | null;
}

interface ApiResponse {
  statusCode: number;
  headers: Record<string, string>;
  body: string;
}

const headers = {
  'Content-Type': 'application/json',
  'Access-Control-Allow-Origin': '*',
};

export async function handler(event: ApiEvent): Promise<ApiResponse> {
  try {
    switch (event.httpMethod) {
      case 'GET':
        return await handleGet(event);
      case 'POST':
        return await handlePost(event);
      case 'PUT':
        return await handlePut(event);
      case 'DELETE':
        return await handleDelete(event);
      default:
        return { statusCode: 405, headers, body: JSON.stringify({ error: 'Method not allowed' }) };
    }
  } catch (error) {
    return {
      statusCode: 500,
      headers,
      body: JSON.stringify({ error: (error as Error).message }),
    };
  }
}

<% if (features.includes('database')) { %>
async function handleGet(event: ApiEvent): Promise<ApiResponse> {
  const id = event.pathParameters?.id;
  if (id) {
    const result = await docClient.send(new GetCommand({
      TableName: TABLE_NAME,
      Key: { PK: id, SK: 'ITEM' },
    }));
    return { statusCode: 200, headers, body: JSON.stringify(result.Item ?? null) };
  }
  const result = await docClient.send(new QueryCommand({
    TableName: TABLE_NAME,
    KeyConditionExpression: 'begins_with(SK, :sk)',
    ExpressionAttributeValues: { ':sk': 'ITEM' },
  }));
  return { statusCode: 200, headers, body: JSON.stringify(result.Items ?? []) };
}

async function handlePost(event: ApiEvent): Promise<ApiResponse> {
  const body = JSON.parse(event.body ?? '{}');
  const id = crypto.randomUUID();
  await docClient.send(new PutCommand({
    TableName: TABLE_NAME,
    Item: { PK: id, SK: 'ITEM', ...body, createdAt: new Date().toISOString() },
  }));
  return { statusCode: 201, headers, body: JSON.stringify({ id }) };
}

async function handlePut(event: ApiEvent): Promise<ApiResponse> {
  const id = event.pathParameters?.id;
  const body = JSON.parse(event.body ?? '{}');
  await docClient.send(new PutCommand({
    TableName: TABLE_NAME,
    Item: { PK: id, SK: 'ITEM', ...body, updatedAt: new Date().toISOString() },
  }));
  return { statusCode: 200, headers, body: JSON.stringify({ id }) };
}

async function handleDelete(event: ApiEvent): Promise<ApiResponse> {
  const id = event.pathParameters?.id;
  await docClient.send(new DeleteCommand({
    TableName: TABLE_NAME,
    Key: { PK: id, SK: 'ITEM' },
  }));
  return { statusCode: 200, headers, body: JSON.stringify({ deleted: true }) };
}
<% } else { %>
async function handleGet(_event: ApiEvent): Promise<ApiResponse> {
  return { statusCode: 200, headers, body: JSON.stringify({ message: 'Hello from <%= name %>!' }) };
}
async function handlePost(event: ApiEvent): Promise<ApiResponse> {
  const body = JSON.parse(event.body ?? '{}');
  return { statusCode: 201, headers, body: JSON.stringify(body) };
}
async function handlePut(event: ApiEvent): Promise<ApiResponse> {
  const body = JSON.parse(event.body ?? '{}');
  return { statusCode: 200, headers, body: JSON.stringify(body) };
}
async function handleDelete(_event: ApiEvent): Promise<ApiResponse> {
  return { statusCode: 200, headers, body: JSON.stringify({ deleted: true }) };
}
<% } %>
